{
  "image_ref": "ubuntu",
  "arch": "aarch64",
  "bundled_by": "proot-cowork",
  "manifest": {
    "schemaVersion": 2,
    "mediaType": "application/vnd.oci.image.manifest.v1+json",
    "annotations": {
      "org.opencontainers.image.title": "ubuntu",
      "org.opencontainers.image.description": "Pre-bundled Ubuntu + XFCE desktop for Proot Cowork",
      "org.opencontainers.image.version": "24.04-xfce"
    }
  },
  "image_config": {
    "architecture": "arm64",
    "os": "linux",
    "config": {
      "Env": [
        "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
      ],
      "Cmd": [
        "/bin/bash"
      ],
      "Labels": {
        "org.opencontainers.image.title": "ubuntu",
        "org.opencontainers.image.version": "24.04-xfce"
      }
    },
    "rootfs": {
      "type": "layers",
      "diff_ids": []
    }
  }
}
